# WW-BrowserAi runs without an external API key by default.
# If you later host your own model server, configure it via WW_BROWSER_AI_URL.
WW_BROWSER_AI_URL="http://localhost:3000/api/ai"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
